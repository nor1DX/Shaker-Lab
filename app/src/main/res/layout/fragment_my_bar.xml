<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/color_bg">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="16dp"
        android:paddingBottom="8dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="My Bar"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/color_text_primary" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_add_ingredient"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="+ Add"
            android:textColor="@color/color_gold"
            android:textSize="13sp"
            app:strokeColor="@color/color_gold"
            app:cornerRadius="18dp" />

    </LinearLayout>

    <!-- Ingredients chips -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:paddingHorizontal="16dp"
        android:paddingBottom="4dp">

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chip_group_ingredients"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

    </HorizontalScrollView>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/color_outline"
        android:layout_marginTop="4dp" />

    <!-- Cocktail grid / empty state -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recycler_my_bar"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="6dp"
            android:clipToPadding="false" />

        <ProgressBar
            android:id="@+id/progress_bar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:indeterminateTint="@color/color_gold"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/text_empty"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="32dp"
            android:visibility="visible">

            <ImageView
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:src="@drawable/ic_my_bar"
                android:alpha="0.25"
                android:contentDescription="@null"
                android:layout_marginBottom="16dp" />

            <TextView
                android:id="@+id/text_empty_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Add ingredients\nto find cocktails"
                android:textSize="16sp"
                android:textColor="@color/color_text_secondary"
                android:gravity="center"
                android:lineSpacingMultiplier="1.4" />

        </LinearLayout>

    </FrameLayout>

</LinearLayout>